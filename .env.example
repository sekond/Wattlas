# Copy to .env and fill in. Free token from your ENTSO-E account:
# https://transparency.entsoe.eu  (Account Settings -> Web API Security Token)
ENTSOE_API_TOKEN=your_token_here

# Optional — RTE Data Portal (https://data.rte-france.com) OAuth2 client credentials.
# Only needed to add French nuclear *available capacity* (the generation-unavailability
# feed) to the France-nuclear view; without these it cleanly degrades to nuclear output.
# Register an application on the portal, subscribe it to the generation/unavailability
# API, then paste the application's client id/secret below.
RTE_CLIENT_ID=your_client_id_here
RTE_CLIENT_SECRET=your_client_secret_here
